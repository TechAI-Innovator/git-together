# Cloudinary (image uploads)
# Use either CLOUDINARY_URL or the three separate values below.
# Fix duplicate prefix if present: use cloudinary://key:secret@cloud_name only
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Base folder; vendor assets go under {folder}/vendors/{restaurant-slug}/logo|cover|menu
CLOUDINARY_UPLOAD_FOLDER=fast_bites/restaurants
